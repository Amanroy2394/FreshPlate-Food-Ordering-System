<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0"
         metadata-complete="true">

  <display-name>FreshPlate</display-name>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- Explicit registration: jetty:run sometimes skips @WebServlet / @WebFilter scanning -->
  <filter>
    <filter-name>CharsetFilter</filter-name>
    <filter-class>com.ehpt.foodorder.web.CharsetFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>CharsetFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <servlet>
    <servlet-name>AuthServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.AuthServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AuthServlet</servlet-name>
    <url-pattern>/auth/login</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AuthServlet</servlet-name>
    <url-pattern>/auth/register</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/auth/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>MenuServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.MenuServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>MenuServlet</servlet-name>
    <url-pattern>/user/menu</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>CartServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.CartServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>CartServlet</servlet-name>
    <url-pattern>/user/cart</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>CartServlet</servlet-name>
    <url-pattern>/user/cart/add</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>CartServlet</servlet-name>
    <url-pattern>/user/cart/update</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>CartServlet</servlet-name>
    <url-pattern>/user/cart/remove</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>OrderServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.OrderServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>OrderServlet</servlet-name>
    <url-pattern>/user/checkout</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>OrderServlet</servlet-name>
    <url-pattern>/user/orders</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminAuthServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.AdminAuthServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminAuthServlet</servlet-name>
    <url-pattern>/admin/login</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AdminAuthServlet</servlet-name>
    <url-pattern>/admin/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminFoodServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.AdminFoodServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminFoodServlet</servlet-name>
    <url-pattern>/admin/foods</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AdminFoodServlet</servlet-name>
    <url-pattern>/admin/foods/new</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AdminFoodServlet</servlet-name>
    <url-pattern>/admin/foods/edit</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AdminFoodServlet</servlet-name>
    <url-pattern>/admin/foods/save</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AdminFoodServlet</servlet-name>
    <url-pattern>/admin/foods/delete</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ApiAuthServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.api.ApiAuthServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ApiAuthServlet</servlet-name>
    <url-pattern>/api/auth/login</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>ApiAuthServlet</servlet-name>
    <url-pattern>/api/auth/register</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>ApiAuthServlet</servlet-name>
    <url-pattern>/api/auth/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ApiFoodServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.api.ApiFoodServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ApiFoodServlet</servlet-name>
    <url-pattern>/api/foods</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>ApiFoodServlet</servlet-name>
    <url-pattern>/api/foods/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ApiCartServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.api.ApiCartServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ApiCartServlet</servlet-name>
    <url-pattern>/api/cart</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>ApiCartServlet</servlet-name>
    <url-pattern>/api/cart/add</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>ApiCartServlet</servlet-name>
    <url-pattern>/api/cart/update</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>ApiCartServlet</servlet-name>
    <url-pattern>/api/cart/remove/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ApiOrderServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.api.ApiOrderServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ApiOrderServlet</servlet-name>
    <url-pattern>/api/orders</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>ApiOrderServlet</servlet-name>
    <url-pattern>/api/orders/*</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>ApiOrderServlet</servlet-name>
    <url-pattern>/api/orders/place</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ApiAdminFoodServlet</servlet-name>
    <servlet-class>com.ehpt.foodorder.web.api.ApiAdminFoodServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ApiAdminFoodServlet</servlet-name>
    <url-pattern>/api/admin/foods</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>ApiAdminFoodServlet</servlet-name>
    <url-pattern>/api/admin/foods/*</url-pattern>
  </servlet-mapping>

</web-app>
